/* Main Application Window & Containers */
QMainWindow {
    background-color: {DARK_BG};
}
QWidget {
    font-family: {FONT_FAMILY};
    color: {TEXT_COLOR};
}

/* Sidebar Styling */
QFrame#sidebar {
    background-color: {SIDEBAR_BG};
    border-right: {BORDER_WIDTH} solid {BORDER_COLOR};
}

/* Content Container Styling */
QWidget#content_container {
    background-color: {DARK_BG};
}

/* Dashboard Page Stats Cards */
QFrame {
    background-color: {CARD_BG};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: {RADIUS};
}

/* Line Edits / Text Areas */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: {DARK_BG};
    color: {TEXT_COLOR};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: {RADIUS};
    padding: 10px;
}
QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border: {BORDER_WIDTH} solid {ACCENT_COLOR};
}

/* Lists */
QListWidget {
    background-color: {DARK_BG};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: 6px;
    color: {TEXT_COLOR};
    padding: 4px;
}
QListWidget::item {
    padding: 8px 10px;
    border-radius: 4px;
}
QListWidget::item:selected {
    background-color: {BORDER_COLOR};
    color: {ACCENT_COLOR};
    font-weight: bold;
}

/* --- Atom Buttons --- */
QPushButton[class="PrimaryButton"] {
    background-color: {ACCENT_COLOR};
    color: {SIDEBAR_BG};
    font-size: 15px;
    font-weight: bold;
    padding: 12px 25px;
    border-radius: {RADIUS};
    border: none;
}
QPushButton[class="PrimaryButton"]:hover {
    background-color: {ACCENT_HOVER};
}

QPushButton[class="NavButton"] {
    color: {TEXT_COLOR};
    background-color: transparent;
    border: none;
    border-left: 4px solid transparent;
    text-align: left;
    padding: 12px 15px;
    font-size: 14px;
    border-radius: 0px;
}
QPushButton[class="NavButton"]:hover {
    background-color: {CARD_BG};
    color: {ACCENT_COLOR};
}
QPushButton[class="NavButton"]:checked {
    background-color: {CARD_BG};
    color: {ACCENT_COLOR};
    border-left: 4px solid {ACCENT_COLOR};
    font-weight: bold;
}

QPushButton[class="SecondaryButton"] {
    background-color: transparent;
    color: {ACCENT_COLOR};
    border: 2px solid {ACCENT_COLOR};
    border-radius: {RADIUS};
    padding: 12px 25px;
    font-weight: bold;
    font-size: 14px;
}
QPushButton[class="SecondaryButton"]:hover {
    background-color: {ACCENT_COLOR};
    color: {SIDEBAR_BG};
}

/* --- Atom Inputs & Labels --- */
QLineEdit[class="FormLineEdit"] {
    background-color: {DARK_BG};
    color: {TEXT_COLOR};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: {RADIUS};
    padding: 10px 14px;
    font-size: 14px;
}
QLineEdit[class="FormLineEdit"]:focus {
    border: {BORDER_WIDTH} solid {ACCENT_COLOR};
}

QCheckBox[class="FormCheckBox"] {
    color: {TEXT_COLOR};
    font-size: 13px;
}
QCheckBox[class="FormCheckBox"]::indicator {
    width: 18px;
    height: 18px;
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: 4px;
    background-color: {DARK_BG};
}
QCheckBox[class="FormCheckBox"]::indicator:checked {
    background-color: {ACCENT_COLOR};
    border: {BORDER_WIDTH} solid {ACCENT_COLOR};
}

QLabel[class="HeaderLabel"] {
    color: {TEXT_COLOR};
}
QLabel[class="SubtitleLabel"] {
    color: {TEXT_COLOR};
}
QLabel[class="BodyLabel"] {
    color: {SUBTEXT_COLOR};
}

/* --- Sidebar Combo & Sub-containers --- */
QComboBox {
    background-color: {SIDEBAR_BG};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    color: {TEXT_COLOR};
    padding: 4px 6px;
    font-size: 11px;
    border-radius: 4px;
}
QComboBox QAbstractItemView {
    background-color: {SIDEBAR_BG};
    color: {TEXT_COLOR};
    selection-background-color: {ACCENT_COLOR};
    selection-color: {SIDEBAR_BG};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
}
QFrame#settings_container, QFrame#path_container {
    background-color: {CARD_BG};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: {RADIUS};
    padding: 6px;
}

/* --- Dashboard Specific Labels --- */
QLabel#project_name_label, QLabel#lbl_new_title {
    color: {ACCENT_COLOR};
}
QLabel#lbl_load_title {
    color: {SUCCESS_COLOR};
}

/* --- Architecture Check Status Labels --- */
QLabel#status_text[theme_status="error"] {
    color: {ERROR_COLOR};
}
QLabel#status_text[theme_status="success"] {
    color: {SUCCESS_COLOR};
}

/* --- Reset/Danger Zone Specific Styles --- */
QLabel#lbl_danger_title {
    color: {ERROR_COLOR};
}
QPushButton#danger_btn {
    background-color: {ERROR_COLOR};
    color: {DARK_BG};
}
QPushButton#danger_btn:hover {
    background-color: {ACCENT_HOVER};
}
QFrame#warning_card {
    border: 2px solid {ERROR_COLOR};
    border-radius: {RADIUS};
}
