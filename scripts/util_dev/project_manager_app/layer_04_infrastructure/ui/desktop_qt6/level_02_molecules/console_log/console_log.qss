QFrame#log_console_frame {
    background-color: {SIDEBAR_BG};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: {RADIUS};
}

QLabel#log_console_title {
    color: {SUBTEXT_COLOR};
    border: none;
    background: transparent;
}

QPushButton#log_console_clear_btn {
    background-color: transparent;
    color: {SUBTEXT_COLOR};
    border: none;
    font-size: 11px;
}
QPushButton#log_console_clear_btn:hover {
    color: {ERROR_COLOR};
}

QTextEdit#log_console_textarea {
    background-color: {DARK_BG};
    color: {TEXT_COLOR};
    border: none;
    border-radius: 4px;
    padding: 8px;
}
