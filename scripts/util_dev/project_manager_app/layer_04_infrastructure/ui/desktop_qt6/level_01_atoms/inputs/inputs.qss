/* --- Atom Inputs --- */
QLineEdit[class="FormLineEdit"] {
    background-color: {DARK_BG};
    color: {TEXT_COLOR};
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: {RADIUS};
    padding: 10px 14px;
    font-size: 14px;
}
QLineEdit[class="FormLineEdit"]:focus {
    border: {BORDER_WIDTH} solid {ACCENT_COLOR};
}

QCheckBox[class="FormCheckBox"] {
    color: {TEXT_COLOR};
    font-size: 13px;
}
QCheckBox[class="FormCheckBox"]::indicator {
    width: 18px;
    height: 18px;
    border: {BORDER_WIDTH} solid {BORDER_COLOR};
    border-radius: 4px;
    background-color: {DARK_BG};
}
QCheckBox[class="FormCheckBox"]::indicator:checked {
    background-color: {ACCENT_COLOR};
    border: {BORDER_WIDTH} solid {ACCENT_COLOR};
}
